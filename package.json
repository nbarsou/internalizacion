{
  "name": "practicum-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "etl": "cd scripts && python etl/main.py",
    "db:seed": "pnpm prisma db seed",
    "db:sync": "pnpm run etl && pnpm prisma db push --force-reset && pnpm db:seed"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
