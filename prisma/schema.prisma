generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// BETTER-AUTH MODELS  (managed by BetterAuth — do not rename fields)
// ============================================================

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ============================================================
// RBAC
// ============================================================

enum Role {
  ADMIN
  EDITOR
  VIEWER
  WAITLISTED
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  role Role @default(WAITLISTED)

  @@map("user")
}

// ============================================================
// REFERENCE TABLES
// Controlled vocabulary — add rows via seed/admin UI,
// never alter the schema to add a new value.
// ============================================================

model RefRegion {
  id           Int          @id @default(autoincrement())
  name         String       @unique @db.VarChar(150)
  universities University[]

  @@map("ref_region")
}

model RefCountry {
  id           Int          @id @default(autoincrement())
  name         String       @unique @db.VarChar(150)
  universities University[]

  @@map("ref_pais")
}

/// Giro — institutional category (e.g. Pública, Privada, Gubernamental).
model RefInstitutionType {
  id           Int          @id @default(autoincrement())
  name         String       @unique @db.VarChar(150)
  universities University[]

  @@map("ref_giro")
}

model RefCampus {
  id           Int          @id @default(autoincrement())
  name         String       @unique @db.VarChar(150)
  universities University[]

  @@map("ref_campus")
}

model RefAgreementType {
  id         Int         @id @default(autoincrement())
  name       String      @unique @db.VarChar(150)
  agreements Agreement[]

  @@map("ref_agreement_type")
}

model RefAttr {
  id             Int             @id @default(autoincrement())
  name           String          @unique @db.VarChar(150)
  agreementAttrs AgreementAttr[]

  @@map("ref_attr")
}

/// Status for agreements only. Universities use soft-delete (deletedAt)
/// to indicate they are no longer active — they don't have operational
/// state the way agreements do.
/// Seed: Activo, En Negociación, No Interesado, Desactivado, Vencido
/// color = hex string used by UI badges e.g. "#22c55e"
model RefStatus {
  id         Int         @id @default(autoincrement())
  value      String      @unique @db.VarChar(150)
  color      String?     @db.VarChar(7)
  agreements Agreement[]

  @@map("ref_status")
}

model RefUtilization {
  id           Int          @id @default(autoincrement())
  value        String       @unique @db.VarChar(150)
  color        String?      @db.VarChar(7)
  universities University[]

  @@map("ref_utilization")
}

model RefBeneficiary {
  id         Int                    @id @default(autoincrement())
  /// Short alphanumeric code (e.g. CC, EG, ZZ, CD).
  /// Preserved from the original referencias.xlsx CVE column.
  cve        String                 @unique @db.VarChar(10)
  name       String                 @unique @db.VarChar(150)
  agreements AgreementBeneficiary[]

  @@map("ref_beneficiary")
}

// ============================================================
// UNIVERSITY
// ============================================================

model University {
  id   String @id @default(uuid())
  /// URL-safe slug for [slug] routes. Generate with slugify(name),
  /// append a counter suffix if a collision occurs.
  slug String @unique @db.VarChar(300)
  name String @db.VarChar(255)

  /// Start of the institutional relationship (Excel: Inicio).
  start   DateTime
  /// End of the MOU validity period (Excel: Vigencia).
  /// Nullable — some agreements are marked "indefinido".
  expires DateTime?

  // ── Metadata ──────────────────────────────────────────────
  isCatholic Boolean @default(false)
  // qs_ranking Int? — dropped, no destination in current scope

  pagina_web String? @db.VarChar(500)

  // ── Location ──────────────────────────────────────────────
  /// Free-text city (~258 unique values — too many for a ref table).
  /// On insert: trim() + pg_trgm similarity check to warn about
  /// near-duplicates ("Madrid" vs "Madrid ") without blocking.
  city    String? @db.VarChar(150)
  address String? @db.VarChar(500)
  /// WGS-84 decimal degrees for map pins.
  lat     Float?
  lng     Float?

  // ── FK references ─────────────────────────────────────────
  regionId Int
  region   RefRegion @relation(fields: [regionId], references: [id])

  countryId Int
  country   RefCountry @relation(fields: [countryId], references: [id])

  /// Nullable — not all Excel rows have a Giro value.
  institutionTypeId Int
  institutionType   RefInstitutionType? @relation(fields: [institutionTypeId], references: [id])

  /// Nullable — not all Excel rows have a Campus Titular value.
  campusId Int
  campus   RefCampus? @relation(fields: [campusId], references: [id])

  /// Nullable — maps from Se_USA. Null source value → find RefUtilization
  /// where value = 'Nula' and store that id rather than leaving null,
  /// so the UI always has a value to display.
  utilizationId Int
  utilization   RefUtilization? @relation(fields: [utilizationId], references: [id])

  // ── Relations ─────────────────────────────────────────────
  contacts     Contact[]
  agreements   Agreement[]
  observations Observation[]

  // ── Timestamps ────────────────────────────────────────────
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /// Soft delete. Filter with: where: { deletedAt: null }
  /// Never hard-delete — use: update: { deletedAt: new Date() }
  deletedAt DateTime?

  @@map("university")
}

// ============================================================
// CONTACT
//
// One university → many contacts.
// The Excel stores Entrantes and Salientes as raw strings that
// may contain a name, an email, a phone, or a mix.
//
// On seed: create one Contact row per non-empty column,
// setting concernType accordingly. If the entrante and saliente
// values are identical, create a single row with concernType=GENERAL
// instead of two duplicates.
//
// valueType lets the UI render the value correctly (mailto: vs tel:).
// If a cell contains both a name and an email, store them as two
// separate Contact rows sharing the same universityId and concernType.
// ============================================================

enum ContactConcernType {
  INCOMING // Contacto Intercambios Entrantes
  OUTGOING // Contacto Intercambios Salientes
  GENERAL // Same person covers both directions
}

enum ContactValueType {
  EMAIL
  PHONE
}

model Contact {
  id           String             @id @default(uuid())
  universityId String
  university   University         @relation(fields: [universityId], references: [id], onDelete: Cascade)
  concernType  ContactConcernType
  valueType    ContactValueType
  name         String?            @db.VarChar(255)
  value        String             @db.VarChar(255)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("contact")
}

// ============================================================
// AGREEMENT
//
// DATA SHAPE — one Excel row expands to multiple Agreement rows:
//   Excel row → 1 University + N Agreements (one per marked type column)
//   Marked columns: INTERCAMBIO, STUDY ABROAD, INVESTIGACIÓN,
//   PRÁCTICAS, DOBLE DIPLOMA, COTUTELA, OTRO
//
// SPOTS encoding (collapsed from two Excel columns):
//   Licenciatura spots  → spots on the Intercambio (typeId=2) agreement
//   Posgrado spots      → spots on the Posgrado-level Intercambio agreement
//   Numeric value       → stored as-is
//   Truthy non-numeric  → stored as 0 (spots exist, count unknown)
//   Falsy / NA / NO     → null (not applicable)
//
// OTRO type:
//   Dynamic RefAgreementType rows inserted at runtime (id ≥ 7).
//   Store the original OTRO cell text in comments for traceability.
//
// STATUS:
//   All ETL-seeded agreements get statusId resolved at seed start
//   via: prisma.refStatus.findFirstOrThrow({ where: { value: 'Activo' } })
//   Cache the result — never hardcode the integer id.
// ============================================================

model Agreement {
  id           String     @id @default(uuid())
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  typeId Int
  type   RefAgreementType @relation(fields: [typeId], references: [id])

  statusId Int
  status   RefStatus @relation(fields: [statusId], references: [id])

  // ── Spots ─────────────────────────────────────────────────
  /// Collapsed from plazas_lic and plazas_pos.
  /// null = not applicable. 0 = exists but count unknown.
  spots Int?

  // ── Scope & flags ─────────────────────────────────────────
  link_convenio String? @db.VarChar(500)

  // ── Junctions ─────────────────────────────────────────────
  beneficiaries AgreementBeneficiary[]
  attrs         AgreementAttr[]

  // ── Observations ──────────────────────────────────────────
  observations Observation[]

  // ── Timestamps ────────────────────────────────────────────
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /// Soft delete. Filter with: where: { deletedAt: null }
  deletedAt DateTime?

  @@map("agreement")
}

// ============================================================
// OBSERVATION
//
// Structured notes attached to either a University or an Agreement.
// Both FKs are nullable — a given observation belongs to one or
// the other, never both. Enforce at the application layer:
//   if (universityId && agreementId) throw new Error(...)
//
// ObservationOrigin:
//   GENERATED   = created by the ETL (e.g. cleaned Excel cell comments,
//            parse warnings, near-duplicate city alerts)
//   MANUAL = created by a user via the admin UI 
// 
// ObservationLevel: Reflects the level of action required
//
// source: fine-grained label for AUTO observations, e.g.:
//   "excel_comment", "etl_validation", "etl_fuzzy_match"
//   Leave null for MANUAL observations.
// ============================================================

enum ObservationOrigin {
  GENERATED
  MANUAL
}

enum ObservationLevel {
  ERROR
  WARNING
  INFO
}

model Observation {
  id   String @id @default(uuid())
  text String @db.Text

  origin ObservationOrigin
  level  ObservationLevel
  /// Fine-grained origin for AUTO observations.
  /// e.g. "excel_comment" | "etl_validation" | "etl_fuzzy_match"
  /// Always null for MANUAL observations.
  source String?           @db.VarChar(100)

  // ── Target (one or the other, never both) ─────────────────
  universityId String?
  university   University? @relation(fields: [universityId], references: [id], onDelete: Cascade)

  agreementId String?
  agreement   Agreement? @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  // ── Timestamps ────────────────────────────────────────────
  createdAt DateTime @default(now())

  @@map("observation")
}

// ============================================================
// JUNCTION TABLES
// ============================================================

model AgreementAttr {
  agreementId String
  attrId      Int
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  attr        RefAttr   @relation(fields: [attrId], references: [id])

  @@id([agreementId, attrId])
  @@map("agreement_attr")
}

model AgreementBeneficiary {
  agreementId   String
  beneficiaryId Int
  agreement     Agreement      @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  beneficiary   RefBeneficiary @relation(fields: [beneficiaryId], references: [id])

  @@id([agreementId, beneficiaryId])
  @@map("agreement_beneficiary")
}
